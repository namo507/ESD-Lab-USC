# ============================================================
# NANO Study — Environment Configuration Template
# Copy to .env and fill in your values.
# NEVER commit .env to the repository.
# ============================================================

# ─── REDCap API ─────────────────────────────────────────────
# Obtain your personal API token from REDCap > My Profile > API
REDCAP_API_TOKEN=your_redcap_api_token_here
REDCAP_API_URL=https://redcap.sc.edu/api/

# REDCap Project IDs (ask PI for values)
REDCAP_PROJECT_ID_MAIN=12345
REDCAP_PROJECT_ID_QUESTIONNAIRES=12346

# ─── Secure Data Drive ──────────────────────────────────────
# Mount point for the USC encrypted research drive
# macOS: /Volumes/nano_secure
# Linux: /mnt/nano_secure
NANO_DATA_ROOT=/Volumes/nano_secure

# ─── Sub-directories (relative to NANO_DATA_ROOT) ───────────
# These are set automatically from config/paths.yml using NANO_DATA_ROOT
# Override here only if your mount differs from standard layout
RAW_ECG_DIR=${NANO_DATA_ROOT}/raw/ecg
PROCESSED_ECG_DIR=${NANO_DATA_ROOT}/processed/ecg
RAW_TEMP_DIR=${NANO_DATA_ROOT}/raw/temperature
PROCESSED_TEMP_DIR=${NANO_DATA_ROOT}/processed/temperature
VIDEO_DIR=${NANO_DATA_ROOT}/raw/video
BEHAVIORAL_CODING_DIR=${NANO_DATA_ROOT}/processed/behavioral_coding
REDCAP_EXPORT_DIR=${NANO_DATA_ROOT}/redcap_exports
MODELS_DIR=${NANO_DATA_ROOT}/models
OUTPUTS_DIR=${NANO_DATA_ROOT}/outputs

# ─── Email Notifications ────────────────────────────────────
# Used by redcap_daily_sync.py to alert PI of issues
SMTP_HOST=smtp.sc.edu
SMTP_PORT=587
SMTP_USER=your_netid@mailbox.sc.edu
SMTP_PASSWORD=your_smtp_password
PI_EMAIL=bradshaw@mailbox.sc.edu
NOTIFY_EMAIL_LIST=bradshaw@mailbox.sc.edu,oreilly@mailbox.sc.edu

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs/

# ─── Public Dashboard Sharing ───────────────────────────────
# The repo supports three sharing modes via `scripts/share_dashboard.sh`:
#
#   make dashboard-share        --mode auto    (default)
#   make share-named            --mode named   (require stable hostname)
#   make share-quick            --mode quick   (force random hostname)
#
# CANONICAL public URLs:
#
#   * Stable named tunnel hostname (Tier 1, preferred)
#       Requires:
#         - Cloudflare account with the DNS zone (e.g. esdlabsc.com) attached.
#         - A named tunnel created in the Cloudflare Zero Trust dashboard
#           with a public hostname mapped to http://dashboard:8080.
#         - The tunnel token + the public hostname both set below.
#       Result: --mode named prints
#         https://dashboard.esdlabsc.com/dashboard/
#       and that hostname stays the same across restarts.
#
#   * Cloudflare Pages wrapper (Tier 2, default fallback)
#       URL: https://esd-lab-namo.pages.dev/
#       The wrapper iframes whichever cloudflared origin is currently live.
#       The share script regenerates the wrapper at
#       dist/pages-wrapper/index.html on every run; deploy it with:
#         make pages-deploy
#       or `npx --yes wrangler@3.112.0 pages deploy dist/pages-wrapper --project-name esd-lab-namo`.
#       Use this when the Cloudflare account does not have the DNS zone wired
#       up for a named tunnel.
#
#   * Quick tunnel only (Tier 3, last resort)
#       https://<random>.trycloudflare.com/dashboard/
#       The hostname rotates on every restart. Never publish this URL.
#
# Leaving both values blank uses Tier 2 (auto → quick origin behind the Pages
# wrapper). Setting only one of the two is an error and the script exits.
CLOUDFLARE_TUNNEL_TOKEN=
DASHBOARD_PUBLIC_HOSTNAME=

# Cloudflare Pages deploy (for `make pages-deploy`):
#   CLOUDFLARE_API_TOKEN   — required by wrangler; scopes Pages:Edit + Account:Read
#   CLOUDFLARE_ACCOUNT_ID  — wrangler auto-picks this up when API token is set
#   CLOUDFLARE_PAGES_PROJECT — Pages project name; defaults to esd-lab-namo
#   CLOUDFLARE_PAGES_BRANCH  — production branch alias; defaults to main
# DASHBOARD_STABLE_SHARE_URL — string the share script can echo as the canonical
#                              URL; defaults to https://esd-lab-namo.pages.dev/
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=esd-lab-namo
CLOUDFLARE_PAGES_BRANCH=main
DASHBOARD_STABLE_SHARE_URL=https://esd-lab-namo.pages.dev/

# ─── Optional Local Dashboard Assistant ─────────────────────
# The local dashboard assistant defaults to a slightly larger Qwen GGUF model
# that improves grounded QA while still fitting this dev container.
DASHBOARD_ASSISTANT_ENABLED=true
DASHBOARD_ASSISTANT_MODEL_ID=bartowski/Qwen2.5-1.5B-Instruct-GGUF
DASHBOARD_ASSISTANT_MODEL_DIR=models/local_llms/Qwen2.5-1.5B-Instruct-GGUF
DASHBOARD_ASSISTANT_MODEL_FILE=Qwen2.5-1.5B-Instruct-Q3_K_S.gguf
DASHBOARD_ASSISTANT_AUTO_DOWNLOAD=false
DASHBOARD_ASSISTANT_DEVICE=cpu
DASHBOARD_ASSISTANT_MAX_NEW_TOKENS=128
DASHBOARD_ASSISTANT_TEMPERATURE=0.05
DASHBOARD_ASSISTANT_TOP_P=0.9
DASHBOARD_ASSISTANT_CONTEXT_BUDGET=6000
DASHBOARD_ASSISTANT_MIN_MEMORY_GIB=1.2
DASHBOARD_ASSISTANT_CONTEXT_WINDOW=1536
DASHBOARD_ASSISTANT_BATCH_SIZE=128
DASHBOARD_ASSISTANT_THREADS=4

# ─── Pipeline Settings ──────────────────────────────────────
N_JOBS=-1  # -1 = use all available CPU cores
RANDOM_SEED=42
